# Plaud
PLAUD_TOKEN=bearer eyJ...
PLAUD_API_DOMAIN=https://api-euc1.plaud.ai

# LLM backend:
# - openai_compatible: direct API via Chat Completions
# - codex_exec: run `codex exec` locally on the machine
#
# For codex_exec:
# 1. install Codex CLI
# 2. run `codex login`
# 3. authenticate with your ChatGPT account or API key
LLM_BACKEND=openai_compatible

# OpenAI-compatible backend settings
# Examples:
# - OpenAI: https://api.openai.com/v1
# - OpenRouter: https://openrouter.ai/api/v1
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4.1-mini

# Codex exec backend settings
CODEX_MODEL=
CODEX_SANDBOX=read-only

# Optional knobs
LLM_MAX_SOURCE_CHARS=22000
LLM_TIMEOUT_SECONDS=120
LLM_TEMPERATURE=0.2

# Optional headers for providers like OpenRouter
LLM_HTTP_REFERER=
LLM_X_TITLE=Plaud2Obsidian
